GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.5-flash

# MapmyIndia/Mappls REST API OAuth credentials from https://apis.mappls.com/console/
MAPMYINDIA_CLIENT_ID=your_mappls_client_id
MAPMYINDIA_CLIENT_SECRET=your_mappls_client_secret

# Optional if you later add the web map SDK.
# MAPMYINDIA_API_KEY=your_mappls_web_api_key
